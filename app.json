{
  "expo": {
    "name": "LevelUp English",
    "slug": "levelup-english",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#5B3BE8"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.ozandokur.levelupenglish"
    },
    "android": {
      "package": "com.ozandokur.levelupenglish",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#5B3BE8"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    }
  }
}
